{
  "version": 2,
  "builds": [
    {
      "src": "index.py",
      "use": "@vercel/python"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "js/*.js",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "project_images/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(public|api|Food|Order)/.*",
      "dest": "index.py"
    },
    {
      "src": "/",
      "dest": "home.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
